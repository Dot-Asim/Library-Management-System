# ========================
# ULMS Project .gitignore
# ========================

# === Java / Maven ===
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
*.class
*.jar
*.war
*.ear
*.log
hs_err_pid*
replay_pid*

# === IDE ===
.idea/
*.iml
*.iws
*.ipr
.vscode/
.settings/
.project
.classpath
.factorypath
*.swp
*.swo
*~

# === Node / Next.js ===
node_modules/
.next/
out/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# === Docker ===
# Don't ignore docker-compose files, but ignore docker data
docker-data/

# === Environment ===
.env
!.env.example

# === OS ===
.DS_Store
Thumbs.db
desktop.ini

# === Project Plan (docs, not code) ===
Project plan/*.txt

# === Misc ===
*.bak
*.tmp
*.temp
